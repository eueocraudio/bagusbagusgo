UBLOCK_ENABLED=true

# Incremento de tamanho de fonte para todos os widgets (labels, inputs, checkboxes, listas...).
# Padrão: 1 (+1pt). 0 = tamanho padrão do sistema. Valores maiores aumentam mais.
ZOOM=1

# Força WebGL ignorando a blocklist do Chromium.
# Útil em ambientes com GPU real. Deixe false em ambientes virtuais/sem GPU.
WEBGL_FORCE=false

# Habilita o bloqueador de anúncios por seletores CSS (ad_blocker.py).
# Padrão: desabilitado.
AD_BLOCKER_ENABLED=false

# Ativa a lista pessoal de seletores CSS (data/ad_selectors.txt).
AD_SELECTOR_PERSONAL_ENABLED=true

# Ativa a lista obtida da internet (data/ad_selectors_web.txt).
# Requer clicar em Update na aba Ad Selectors > Lista da Internet.
AD_SELECTOR_WEB_ENABLED=false

# Liga as flags de multithreading do Chromium (site-per-process, GPU rasterization,
# zero-copy, num-raster-threads, ParallelDownloading). Padrão: true.
MULTITHREAD_ENABLED=true

# Número de threads de rasterização do Chromium (--num-raster-threads).
# Vazio = min(núcleos da CPU, 4). Só tem efeito com MULTITHREAD_ENABLED=true.
# CHROMIUM_RASTER_THREADS=4
ZOOM=5
